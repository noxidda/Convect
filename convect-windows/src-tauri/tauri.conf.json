{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Convect",
  "version": "0.1.0",
  "identifier": "com.convect.desktop",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev --prefix client",
    "beforeBuildCommand": "npm run build --prefix client"
  },
  "app": {
    "windows": [
      {
        "title": "Convect",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
